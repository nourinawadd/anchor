{
  "expo": {
    "name": "Anchor",
    "slug": "anchor",
    "scheme": "anchor",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#313852"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.gradproject.anchor",
      "infoPlist": {
        "NFCReaderUsageDescription": "Anchor uses NFC to verify your physical presence at your focus location during sessions.",
        "NSFamilyControlsUsageDescription": "Anchor uses Screen Time to shield distracting apps during your focus sessions.",
        "NSCalendarsUsageDescription": "Anchor uses your Calendar to show today's schedule and to add your completed focus sessions as events.",
        "NSCalendarsFullAccessUsageDescription": "Anchor uses your Calendar to show today's schedule and to add your completed focus sessions as events.",
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      },
      "buildNumber": "52",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.family-controls": true
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Anchor uses NFC to verify your physical presence at your focus location during sessions.",
          "includeNdefEntitlement": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.129531586894-j4idsokok0s7nvlb3lifbhkpvh4dmg9j"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#313852"
        }
      ],
      [
        "@bacons/apple-targets",
        {
          "appleTeamId": "SGMRDRZ92B"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "dev.gradproject.anchor.widget",
                  "targetName": "AnchorWidget"
                },
                {
                  "bundleIdentifier": "dev.gradproject.anchor.widget",
                  "targetName": "AnchorWidget"
                }
              ]
            }
          }
        },
        "projectId": "af2d20fd-3851-4e3d-b2b4-935ce3cdfd2b"
      }
    },
    "owner": "nourinawaddd"
  }
}
